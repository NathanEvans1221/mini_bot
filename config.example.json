{
  "_comment": "建議使用環境變數：export MINIMAX_API_KEY='your-key' && export TELEGRAM_BOT_TOKEN='your-token'",
  "agents": {
    "defaults": {
      "model": "minimax/MiniMax-M2.5",
      "maxTokens": 8192,
      "temperature": 0.7,
      "maxToolIterations": 20,
      "memoryWindow": 50,
      "workspace": "~/.minibot/workspace"
    }
  },
  "providers": {
    "minimax": {
      "apiKey": "",
      "apiBase": "https://api.minimax.io/v1"
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "",
      "allow_from": [
        "your-telegram-user-id-here"
      ]
    }
  }
}